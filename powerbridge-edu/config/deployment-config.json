{
  "site_name": "Local Deployment",
  "source_name": "simulator",
  "csv_path": "data/deployment-telemetry.csv",
  "polling_interval_seconds": 5,
  "phases": ["L1", "L2", "L3", "N"],
  "enabled_metrics": [
    "voltage",
    "current",
    "active_power",
    "apparent_power",
    "reactive_power",
    "power_factor",
    "frequency"
  ],
  "influx_enabled": true,
  "influx_url": "http://influxdb:8086",
  "influx_org": "powerbridge",
  "influx_bucket": "telemetry",
  "influx_token": "powerbridge-dev-token",
  "influx_measurement": "powerbridge"
}
